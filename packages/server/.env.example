PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
ADMIN_EMAILS=admin@example.com,you@yourdomain.com
# Per-turn game clock (NOT WebRTC TURN — see Cloudflare vars below).
TURN_TIMEOUT_MS=10000
MAX_PLAYERS=4
GRACE_PERIOD_MS=60000
ROOM_EXPIRY_MS=3600000

# --- Database (Phase 6 onwards) ---
# Postgres connection string (e.g., from Neon, Railway, or local dev).
# For v1, the server still runs without a DB (in-memory mode).
# Leave unset to skip DB initialization.
# Example: postgresql://user:password@host:5432/ganatri
DATABASE_URL=

# --- Voice chat: Cloudflare Realtime TURN (free tier: 1 TB relayed/month) ---
# Create a TURN key: Cloudflare dashboard → Realtime → TURN → Create.
# Without these, voice falls back to STUN-only (works same-network, may fail
# across restrictive/cellular NATs). The API token stays server-side; clients
# only ever receive short-lived generated credentials.
CLOUDFLARE_TURN_KEY_ID=your_turn_key_id
CLOUDFLARE_TURN_API_TOKEN=your_turn_key_api_token
# Lifetime of minted TURN credentials, in seconds (default 3600).
CLOUDFLARE_TURN_TTL_S=3600

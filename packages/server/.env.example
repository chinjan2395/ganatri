PORT=4000
HOST=0.0.0.0
# Public origin of the web client. When set, CORS locks to this origin and
# allows credentials (cookies) on both HTTP and Socket.io; required for OAuth
# login cookies and post-login redirects. When unset, CORS falls back to '*'
# WITHOUT credentials. (Supersedes the old CORS_ORIGIN var.)
WEB_ORIGIN=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
ADMIN_EMAILS=admin@example.com,you@yourdomain.com
# Shared secret required for admin auth. If set, must be supplied in admin_auth payload.
ADMIN_SECRET=

# --- Optional Google OAuth login (Phase B) ---
# All three must be set to enable login; otherwise /auth/* routes 404 and the
# server stays guest-only. Create credentials in Google Cloud Console →
# APIs & Services → Credentials → OAuth client ID (Web application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI on the OAuth client, e.g.
# https://your-server/auth/google/callback
OAUTH_REDIRECT_URI=
# Days a server-issued session token (ganatri_session cookie) stays valid.
SESSION_TTL_DAYS=30
# LOCAL DEV ONLY. Set to "true" to drop the `Secure` attribute on auth cookies
# so OAuth login works over http://localhost (browsers drop Secure cookies on
# plain HTTP, which otherwise makes the state-cookie CSRF check 400). NEVER set
# this in production — leave it unset so cookies stay Secure.
INSECURE_COOKIES=
# Per-turn game clock (NOT WebRTC TURN — see Cloudflare vars below).
TURN_TIMEOUT_MS=10000
MAX_PLAYERS=4
GRACE_PERIOD_MS=60000
ROOM_EXPIRY_MS=3600000

# --- Database (Phase 6 onwards) ---
# Postgres connection string (e.g., from Neon, Railway, or local dev).
# For v1, the server still runs without a DB (in-memory mode).
# Leave unset to skip DB initialization.
# Example: postgresql://user:password@host:5432/ganatri
DATABASE_URL=

# --- Voice chat: Cloudflare Realtime TURN (free tier: 1 TB relayed/month) ---
# Create a TURN key: Cloudflare dashboard → Realtime → TURN → Create.
# Without these, voice falls back to STUN-only (works same-network, may fail
# across restrictive/cellular NATs). The API token stays server-side; clients
# only ever receive short-lived generated credentials.
CLOUDFLARE_TURN_KEY_ID=your_turn_key_id
CLOUDFLARE_TURN_API_TOKEN=your_turn_key_api_token
# Lifetime of minted TURN credentials, in seconds (default 3600).
CLOUDFLARE_TURN_TTL_S=3600

{
  "name": "@ganatri/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "dev:alt": "PORT=4001 WEB_ORIGIN=http://localhost:5174 CORS_ORIGIN=http://localhost:5174 tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ganatri/db": "0.0.0",
    "@ganatri/engine": "*",
    "google-auth-library": "^10.7.0",
    "socket.io": "^4.8.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}

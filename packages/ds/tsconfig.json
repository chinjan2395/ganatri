{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@ganatri/ds": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.stories.tsx", "node_modules"]
}
